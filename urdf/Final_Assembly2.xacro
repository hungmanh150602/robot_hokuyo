<?xml version="1.0"?>

<robot name="Final_Assembly2" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="ofset_z" value = "0.032"/>

  <!-- ######################### base_footprint ######################### -->
  <link name="base_footprint">
  </link>

  <!-- ######################### base_link ######################### -->
  <link name="base_link">
    <inertial>
      <origin
        xyz="0.00119425624201991 9.90028783521845E-06 0.126920808175509"
        rpy="0 0 0" />
      <mass
        value="0.560450964958611" />
      <inertia
        ixx="0.00105600778155876"
        ixy="-6.190638119024E-08"
        ixz="8.73846346168811E-06"
        iyy="0.000862320766772729"
        iyz="-6.26543063625838E-07"
        izz="0.000674518878809491" />
    </inertial>

    <visual>
      <origin xyz="0 0 ${ofset_z}" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/base_link.STL" />
      </geometry>

      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 ${ofset_z}" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin
      xyz="0 0 ${ofset_z}"
      rpy="0 0 0"/>
  </joint>

  <!-- ######################### right_wheel ######################### -->
  <link name="right_wheel">
    <inertial>
      <origin
        xyz="1.24935486049348E-10 -0.00121008827603855 -8.45574168843732E-10"
        rpy="0 0 0" />
      <mass
        value="0.035174499073282" />
      <inertia
        ixx="1.52365647079397E-05"
        ixy="3.85214772125326E-14"
        ixz="-4.05853136736071E-11"
        iyy="2.57857402471617E-05"
        iyz="-3.87897448468681E-13"
        izz="1.52375555448767E-05" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/right_wheel.STL" />
      </geometry>

      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/right_wheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_joint" type="continuous">
    <origin
      xyz="0 -0.118455251014682 ${ofset_z -0.0311999999999991}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="right_wheel" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ######################### left_wheel ######################### -->
  <link name="left_wheel">
    <inertial>
      <origin
        xyz="-1.24932742139529E-10 0.00121008827603861 -8.45574106393687E-10"
        rpy="0 0 0" />
      <mass
        value="0.035174499073282" />
      <inertia
        ixx="1.52365647079397E-05"
        ixy="3.85214773307735E-14"
        ixz="4.05853136736088E-11"
        iyy="2.57857402471617E-05"
        iyz="3.87897448292234E-13"
        izz="1.52375555448767E-05" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/left_wheel.STL" />
      </geometry>

      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/left_wheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_joint" type="continuous">
    <origin
      xyz="0 0.118455251014682 ${ofset_z -0.0311999999999989}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="left_wheel" />
    <axis xyz="0 -1 0" />
  </joint>

  <!-- ######################### front_caster ######################### -->
  <link name="front_caster">
    <inertial>
      <origin
        xyz="0.0119342492391004 -0.000364594873160433 -0.0120670467949858"
        rpy="0 0 0" />
      <mass
        value="0.00560471940158242" />
      <inertia
        ixx="4.69262301118342E-07"
        ixy="1.12491553537142E-08"
        ixz="9.18879942417866E-08"
        iyy="5.96229046503367E-07"
        iyz="-1.3547265919479E-08"
        izz="5.00134110758663E-07" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/front_caster.STL" />
      </geometry>

      <material name="">
        <color rgba="0.352941176470588 0.352941176470588 0.352941176470588 1" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/front_caster.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="front_joint" type="fixed">
    <origin
      xyz="0.0812188938412163 0.000322234423224879 ${ofset_z -0.0395}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="front_caster" />
    <axis xyz="0 0 0" />
  </joint>

  <!-- ######################### back_caster ######################### -->
  <link name="back_caster">
    <inertial>
      <origin
        xyz="0.0119383156811677 -0.000189370491167673 -0.012067046930885"
        rpy="0 0 0" />
      <mass
        value="0.00560471919698078" />
      <inertia
        ixx="4.68959414965462E-07"
        ixy="9.38079468789928E-09"
        ixz="9.20769376585221E-08"
        iyy="5.96531891349892E-07"
        iyz="-1.2196985578877E-08"
        izz="5.00134085801116E-07" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/back_caster.STL" />
      </geometry>

      <material name="">
        <color rgba="0.352941176470588 0.352941176470588 0.352941176470588 1" />
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/back_caster.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="back_joint" type="fixed">
    <origin
      xyz="-0.081000000000001 0 ${ofset_z -0.0395}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="back_caster" />
    <axis xyz="0 0 0" />
  </joint>

  <!-- ######################### lidar_link ######################### -->
  <link name="lidar_link">
    <inertial>
      <origin
        xyz="-0.00112908293604255 0.000128963727313976 -0.0385815004184485"
        rpy="0 0 0" />
      <mass
        value="0.173803670651051" />
      <inertia
        ixx="0.000129758118904503"
        ixy="2.43871082141114E-07"
        ixz="4.69836973987065E-06"
        iyy="0.000130408373448519"
        iyz="5.30533522719505E-07"
        izz="7.30689593875648E-05" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/laser_link.STL" />
      </geometry>

      <material name="">
        <color rgba="0.701960784313725 0.552941176470588 0.00392156862745098 1" />
      </material>
    </visual>

    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh filename="package://lidar_hokuyo/meshes/laser_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin
      xyz="-0.000120545623894024 0 ${ofset_z + 0.432423653999763}"
      rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar_link" />
    <axis xyz="0 0 0" />
  </joint>

  <!-- Odomertry -->
  <gazebo>
    <plugin name='diff_drive' filename='libgazebo_ros_diff_drive.so'>
      <!--wheel-->
      <left_joint>left_joint</left_joint>
      <right_joint>right_joint</right_joint>

      <!-- kinematics -->
      <wheel_separation>0.236</wheel_separation>
      <wheel_diameter>0.13</wheel_diameter>

      <!-- limits -->
      <max_wheel_torque>80</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <!-- output -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

</robot>